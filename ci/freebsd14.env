# Pinned FreeBSD release for the ci/freebsd-*.sh scripts, with the official
# hashes of the artifacts fetched at run time: the amd64 + arm64 VM images
# and the base.txz sets the link sysroots come from. Generated by
# ci/freebsd-pin.sh -- edit that, not this. Renovate bumps RELEASE when a new
# 14.x point release ships (custom manager in renovate.json; majors move by
# hand: the oldest supported major gives static binaries the widest reach).
# Renovate cannot refresh the hashes, so its bump PR stays red on the
# checksum gates until `ci/freebsd-pin.sh` runs on its branch.
# renovate: datasource=endoflife-date depName=freebsd
RELEASE=14.4
IMAGE_URL_AMD64=https://download.freebsd.org/releases/VM-IMAGES/14.4-RELEASE/amd64/Latest/FreeBSD-14.4-RELEASE-amd64-BASIC-CLOUDINIT-ufs.qcow2.xz
IMAGE_URL_ARM64=https://download.freebsd.org/releases/VM-IMAGES/14.4-RELEASE/aarch64/Latest/FreeBSD-14.4-RELEASE-arm64-aarch64-BASIC-CLOUDINIT-ufs.qcow2.xz
IMAGE_SHA512_AMD64=8f1c7ef058259f0bb3d087ae31238021915832b6eb7a7d9bd438ad2c1aca42258c4b09e196bcc1487f0bab55663de28b9c26cc1eb2faa69b06dc7f1aca882af8
IMAGE_SHA512_ARM64=a0870781153e3725280d7d54586e5cd5705e962ac7a7220567f78e1f639ad7bf9d137aa4d5a6701bc5694093919c4c7e4317b6a72b3b2941e01deb581d5772f6
BASE_URL_AMD64=https://download.freebsd.org/releases/amd64/14.4-RELEASE/base.txz
BASE_URL_ARM64=https://download.freebsd.org/releases/arm64/aarch64/14.4-RELEASE/base.txz
BASE_SHA256_AMD64=769f60a6eea2938ad6b7943cfbcc17dfaf7d1f7ba59a32b869a00349302df853
