# Pinned FreeBSD release for the ci/freebsd-*.sh scripts, with the official
# hashes of the artifacts fetched at run time: the amd64 + arm64 VM images
# and the base.txz sets the link sysroots come from. Generated by
# ci/freebsd-pin.sh -- edit that, not this. Renovate bumps RELEASE when a new
# 15.x point release ships (custom manager in renovate.json; majors move by
# hand: the oldest supported major gives static binaries the widest reach).
# Renovate cannot refresh the hashes, so its bump PR stays red on the
# checksum gates until `ci/freebsd-pin.sh` runs on its branch.
# renovate: datasource=endoflife-date depName=freebsd
RELEASE=15.1
IMAGE_URL_AMD64=https://download.freebsd.org/releases/VM-IMAGES/15.1-RELEASE/amd64/Latest/FreeBSD-15.1-RELEASE-amd64-BASIC-CLOUDINIT-ufs.qcow2.xz
IMAGE_URL_ARM64=https://download.freebsd.org/releases/VM-IMAGES/15.1-RELEASE/aarch64/Latest/FreeBSD-15.1-RELEASE-arm64-aarch64-BASIC-CLOUDINIT-ufs.qcow2.xz
IMAGE_SHA512_AMD64=bea82b91a983a20eb7ecdc6f11c1006d394ebbc5668b7f0ecdecf5a54fc5f9ea3a8384fc9f74a6611a9b08c183fa953327147ebfaa0de199fd015e67dd1e608a
IMAGE_SHA512_ARM64=df37de822fffdf19d7dddfdd3947390b5ae4dcd7f18a5ef6c6e6bb22effd52b593e09970c85ae081a2bb8290bad99a0fa5e473aed41be332a47bbac62c62bfb4
BASE_URL_AMD64=https://download.freebsd.org/releases/amd64/15.1-RELEASE/base.txz
BASE_URL_ARM64=https://download.freebsd.org/releases/arm64/aarch64/15.1-RELEASE/base.txz
BASE_SHA256_AMD64=3768988b151c20f965679062b065c63a977d6bbb9f47fd83695ec2c40790c18f
