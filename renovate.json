{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["ci/freebsd.env"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)\\nRELEASE=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["freebsd"],
      "allowedVersions": "/^14\\./"
    }
  ]
}
